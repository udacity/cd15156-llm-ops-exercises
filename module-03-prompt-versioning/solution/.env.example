# === API Keys ===
OPENAI_API_KEY=sk-your-openai-api-key
# Leave OPENAI_BASE_URL blank for the stock OpenAI API. If your course
# workspace issues a Vocareum key (prefix `voc-`), set it to:
#   OPENAI_BASE_URL=https://openai.vocareum.com/v1
OPENAI_BASE_URL=

# === Chroma (Vector DB) ===
# Embedded persistent client — no Docker, no server. Override the path
# only if you want the on-disk store somewhere other than data/chroma.
# CHROMA_PATH=data/chroma

# === Tracing — Module 09 ===
# "phoenix" launches an in-process Phoenix UI at http://localhost:6006.
# Tracing is a Module 09 topic, so this module ships it off ("none") to
# keep startup quiet; you turn it on when you reach that module.
TRACING_BACKEND=none
# PHOENIX_EMBEDDED=true
# PHOENIX_HOST=0.0.0.0
# PHOENIX_PORT=6006
# PHOENIX_WORKING_DIR=data/phoenix
# PHOENIX_PROJECT_NAME=scikitdocs

# === Models ===
MODEL_COMPLEX=gpt-4o
MODEL_SIMPLE=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# === Application ===
CONFIDENCE_THRESHOLD=0.7
COST_LOG_PATH=data/cost_log.jsonl

# === Feature flags ===
# The starter ships the full ScikitDocs app, including subsystems taught
# in later modules. They are switched off here so a later concept does
# not mask this module's lesson: the semantic answer cache is Module 15,
# the LLM-judge output guard is Module 20. Leave them off for this
# module's exercises.
ENABLE_SEMANTIC_CACHE=false
ENABLE_OUTPUT_GUARD=false
